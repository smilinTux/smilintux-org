# ═══════════════════════════════════════════════════════════════════════════════
# Sovereign Agent Stack — Environment Variables
#
# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
#   $EDITOR .env
#   docker compose up -d
#
# Mark: REQUIRED = must be set; OPTIONAL = has a sensible default.
# ═══════════════════════════════════════════════════════════════════════════════

# ── AI / LLM ─────────────────────────────────────────────────────────────────

# REQUIRED: Anthropic API key for skcapstone agent sessions
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=

# OPTIONAL: Default model for agent sessions
AGENT_MODEL=claude-sonnet-4-6

# OPTIONAL: Research model (used by task-master tooling)
MODEL=claude-sonnet-4-6
MAX_TOKENS=64000
TEMPERATURE=0.2

# OPTIONAL: Perplexity API key (for research ops in task-master)
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro

# ── Agent Identity ────────────────────────────────────────────────────────────

# OPTIONAL: Sovereign agent instance name (default: opus)
AGENT_NAME=opus

# OPTIONAL: Parent team name (default: skworld)
TEAM_NAME=skworld

# OPTIONAL: Agent role (default: coordinator)
AGENT_ROLE=coordinator

# ── SKComm Transport ──────────────────────────────────────────────────────────

# REQUIRED for WebRTC: HMAC secret shared between coturn, skchat, and skcomm.
# Must be identical to COTURN_AUTH_SECRET.
# Generate: openssl rand -hex 32
SKCOMM_TURN_SECRET=

# OPTIONAL: TURN server URL (default: turn:turn.skworld.io:3478)
# When running coturn locally, use: turn:localhost:3478
SKCOMM_TURN_URL=turn:turn.skworld.io:3478

# OPTIONAL: WebRTC signaling relay URL
# When running weblink-signaling locally: ws://localhost:8787
# Production endpoint: wss://ws.weblink.skworld.io
SKCOMM_SIGNALING_URL=wss://ws.weblink.skworld.io

# OPTIONAL: Remote CapAuth validation API (leave blank for local-only mode)
CAPAUTH_API_URL=

# OPTIONAL: Dev-mode auth bypass — NEVER set in production
# SKCOMM_DEV_AUTH=i_know_what_im_doing

# ── skchat Daemon ─────────────────────────────────────────────────────────────

# OPTIONAL: Polling interval in seconds (default: 5.0)
SKCHAT_DAEMON_INTERVAL=5.0

# OPTIONAL: CapAuth identity URI (e.g. capauth:opus@skworld.io)
SKCHAT_IDENTITY=

# ── Skills Registry ───────────────────────────────────────────────────────────

# OPTIONAL: Remote skills registry URL
SKSKILLS_REGISTRY_URL=https://skills.smilintux.org

# OPTIONAL: Admin token for skills-registry service (leave blank to disable admin ops)
REGISTRY_ADMIN_TOKEN=

# OPTIONAL: Allow unauthenticated skill publishing (false = admin token required)
REGISTRY_OPEN_PUBLISH=false

# ── Memory Backends ───────────────────────────────────────────────────────────

# OPTIONAL: Qdrant vector store (default: http://qdrant:6333 when using compose)
SKMEMORY_SKVECTOR_URL=http://qdrant:6333

# OPTIONAL: Qdrant API key (leave blank if using unauthenticated local instance)
SKMEMORY_SKVECTOR_KEY=

# OPTIONAL: FalkorDB / Redis graph store (default: redis://falkordb:6379)
SKMEMORY_SKGRAPH_URL=redis://falkordb:6379

# ── coturn STUN/TURN Server (--profile turn) ──────────────────────────────────

# REQUIRED for coturn: Public IP of the host running coturn (needed for NAT traversal)
# Find it with: curl -s https://ifconfig.me
COTURN_EXTERNAL_IP=

# REQUIRED for coturn: HMAC secret for time-limited TURN credentials
# Generate: openssl rand -hex 32
# Must be identical to SKCOMM_TURN_SECRET
COTURN_AUTH_SECRET=

# OPTIONAL: TLS certificate paths inside the coturn container
# Mount the cert directory via COTURN_CERTS_DIR below
COTURN_TLS_CERT=/etc/coturn/certs/fullchain.pem
COTURN_TLS_PKEY=/etc/coturn/certs/privkey.pem

# OPTIONAL: Host directory to mount as /etc/coturn/certs (read-only)
# Default: /etc/letsencrypt/live/turn.skworld.io
COTURN_CERTS_DIR=/etc/letsencrypt/live/turn.skworld.io

# OPTIONAL: Override published coturn ports
COTURN_PORT=3478
COTURN_TLS_PORT=5349

# ── weblink-signaling Wrangler Dev (--profile signaling) ─────────────────────

# OPTIONAL for local dev (required for `wrangler deploy` to Cloudflare):
# Cloudflare account ID — find at dash.cloudflare.com → Workers & Pages
CF_ACCOUNT_ID=

# OPTIONAL for local dev (required for `wrangler deploy`):
# Cloudflare API token with Workers:Edit permission
CLOUDFLARE_API_TOKEN=

# OPTIONAL: Wrangler dev port (default: 8787)
WEBLINK_PORT=8787

# ── Syncthing (--profile sync) ────────────────────────────────────────────────

# OPTIONAL: Syncthing GUI and sync port overrides
SYNCTHING_GUI_PORT=8384
SYNCTHING_LISTEN_PORT=22000

# OPTIONAL: UID/GID for Syncthing file ownership (default: 1000)
PUID=1000
PGID=1000

# ── Backing Service Ports ─────────────────────────────────────────────────────

# OPTIONAL: Qdrant REST and gRPC port overrides
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334

# OPTIONAL: FalkorDB port override (Redis-compatible)
FALKORDB_PORT=6379

# OPTIONAL: Skills registry host port (maps to 8080 in container)
SKILLS_REGISTRY_PORT=8082

# ── Cloud / Infrastructure (optional) ────────────────────────────────────────

# Hetzner Cloud
HETZNER_API_TOKEN=

# Tailscale
TAILSCALE_AUTHKEY=

# Proxmox
PROXMOX_HOST=
PROXMOX_USER=root@pam
PROXMOX_TOKEN_NAME=
PROXMOX_TOKEN_VALUE=

# ── GitHub Actions Secrets (skstacks/v2/cicd/github/deploy.yml) ──────────────
#
# Set these under repo Settings → Secrets and variables → Actions.
# Do NOT put real values here — this file is committed to source control.
#
# Authentication / SSH
# REQUIRED: ED25519 private key for Ansible SSH access to deployment targets.
# Used when secret_backend != hashicorp-vault (vault-file or capauth flows).
# Generate: ssh-keygen -t ed25519 -C deploy@ci
ANSIBLE_SSH_PRIVATE_KEY=

# HashiCorp Vault — OIDC JWT auth (no static VAULT_TOKEN or AppRole secrets needed)
# REQUIRED for secret_backend=hashicorp-vault: base URL of your Vault cluster.
# Example: https://vault.skworld.io
VAULT_ADDR=

# vault-file backend — Ansible Vault pass-phrases (one per environment)
# REQUIRED if secret_backend=vault-file and the target env is used.
# Generate: openssl rand -base64 32
VAULT_PASS_PROD=
VAULT_PASS_STAGING=
VAULT_PASS_DEV=

# Kubernetes / RKE2 access
# REQUIRED for K8s/RKE2 deploys: base64-encoded kubeconfig for each environment.
# Generate: base64 -w0 ~/.kube/config-prod
KUBECONFIG_PROD=
KUBECONFIG_STAGING=

# ArgoCD sync
# REQUIRED for ArgoCD post-deploy sync: ArgoCD server hostname (no https://).
# Example: argocd.skworld.io
ARGOCD_SERVER=
# REQUIRED for ArgoCD sync: API token with app sync permissions.
# Generate: argocd account generate-token --account ci
ARGOCD_TOKEN=

# ── Dev / Debug ───────────────────────────────────────────────────────────────

DEBUG=false
LOG_LEVEL=info
DEFAULT_SUBTASKS=5
DEFAULT_PRIORITY=medium
PROJECT_NAME=skcapstone
