# weblink-signaling Environment Variables
# Copy to .env and fill in values for your deployment.

# --- Cloudflare Account ---
# Cloudflare account ID (used in wrangler.toml as ${CF_ACCOUNT_ID}).
# CF_ACCOUNT_ID=

# --- CORS / Origins ---
# Comma-separated list of allowed origins for WebSocket connections.
# Default (dev): "*"
# Production example: "https://skworld.io,https://skchat.skworld.io,https://weblink.skworld.io"
# ALLOWED_ORIGINS=*

# --- Cloudflare API (for wrangler deploys) ---
# Cloudflare API token with Workers permissions.
# CLOUDFLARE_API_TOKEN=

# --- TURN Server (used by WebRTC peers) ---
# HMAC secret for generating time-limited TURN credentials (shared with coturn).
# SKCOMM_TURN_SECRET=
